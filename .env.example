# Base URL the client uses to reach the Eruja API.
# Empty string = same-origin Next.js Route Handlers under /api (the reference backend).
# Point this at the real Go/Python backend origin (e.g. https://api.eruja.app) to swap it in
# with zero client changes. A cross-origin backend MUST enable CORS for the web origin and
# reproduce the eruja_session httpOnly cookie contract. See docs/api-contract.md.
NEXT_PUBLIC_API_BASE_URL=
